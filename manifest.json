{
  "manifest_version": 3,
  "name": "Authenticate to Ntfy",
  "version": "1.2",
  "browser_specific_settings": {
    "gecko": {
      "id": "link-ntfy-notifier@jovandeginste",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "websiteContent"
        ]
      }
    }
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://idp.kuleuven.be/*",
    "https://idp.t.icts.kuleuven.be/*",
    "https://idp.q.icts.kuleuven.be/*",
    "https://ntfy.sh/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://idp.kuleuven.be/*",
        "https://idp.t.icts.kuleuven.be/*",
        "https://idp.q.icts.kuleuven.be/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
